{
  "name": "podcast-sync",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run build && wrangler dev --ip 0.0.0.0",
    "deploy": "wrangler deploy",
    "build": "npm run build:css && npm run build:worker && npm run build:frontend",
    "build:css": "npx @tailwindcss/cli -i src/assets/source.css -o dist/global.css --minify && cp dist/global.css src/assets/global.css",
    "build:worker": "esbuild src/index.ts src/api.ts src/do.ts --bundle --format=esm --outdir=dist --out-extension:.js=.js --external:cloudflare:workers",
    "build:frontend": "esbuild src/main.ts --bundle --format=iife --outfile=src/assets/main.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@tailwindcss/cli": "^4.2.4",
    "esbuild": "^0.24.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.3",
    "wrangler": "^3.109.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "hono": "^4.8.1"
  }
}
